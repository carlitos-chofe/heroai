# Base de datos PostgreSQL
DATABASE_URL=postgresql+psycopg://hero:hero@localhost:5432/hero_ai

# Redis (broker Celery)
REDIS_URL=redis://localhost:6379/0

# Google AI
GOOGLE_API_KEY=
GOOGLE_TEXT_MODEL=gemini-2.5-pro
GOOGLE_IMAGE_MODEL=gemini-2.5-flash-preview-image-generation
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# Clerk (autenticación)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Frontend → API
NEXT_PUBLIC_API_BASE_URL=http://heroai.local:8000

# Almacenamiento local de assets
LOCAL_ASSET_DIR=/app/storage

# CORS (separar por comas si hay múltiples)
CORS_ALLOW_ORIGINS=http://heroai.local:3000
